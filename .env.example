# ==========================================
# NEXUS LATAM — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ==========================================

# ── Bitso Business ─────────────────────────────
BITSO_API_KEY=your_bitso_api_key_here
BITSO_API_SECRET=your_bitso_api_secret_here
BITSO_SANDBOX=true

# ── Arbitrum ────────────────────────────────────
ARBITRUM_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_MAINNET_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
PRIVATE_KEY=0x_your_wallet_private_key

# ── Contract Addresses (after deploy) ──────────
TRADE_ESCROW_ADDRESS=0x...
BATCH_PAYMENT_ADDRESS=0x...
NEXUS_VAULT_ADDRESS=0x...
COMPLIANCE_REGISTRY_ADDRESS=0x...
USDC_ADDRESS=0xFF970A61A04b1cA14834A43f5dE4533eBDDB5CC8
MXNB_ADDRESS=0x...

# ── Rare Protocol ────────────────────────────────
RARE_CHAIN=sepolia

# ── Claude / Anthropic ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── IPFS / Pinata ────────────────────────────────
PINATA_API_KEY=your_pinata_key
PINATA_SECRET=your_pinata_secret

# ── Frontend (Next.js public vars) ──────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001/events
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
FRONTEND_URL=http://localhost:3000

# ── App ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
